# --- App ---
APP_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-string

# --- Elasticsearch ---
# Local dev: docker single-node with security off.
ELASTICSEARCH_URL=http://localhost:9200
# Production (Contabo/EasyPanel): set URL + one auth method below.
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_INSECURE_TLS=   # set to 1 only if using self-signed cert

# --- AbacatePay (Pix) ---
ABACATEPAY_API_KEY=
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v2
ABACATEPAY_WEBHOOK_SECRET=change-me

# --- PostHog (analytics de visitantes) ---
# Chave do projeto (phc_...). Sem ela, o tracking fica desligado.
# Read at runtime by the server and passed to the client — no build arg needed.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
